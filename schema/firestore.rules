rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    // Users can read any profile; can only write their own document.
    // followingCount and followerCount fields are updated in the same batch write
    // as the corresponding following/followers subcollection documents.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow any authenticated user to increment/decrement followerCount only
      // (written atomically as part of a follow/unfollow batch write).
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount']);

      // following subcollection: owner may create/delete their own following entries;
      // any authenticated user may read any user's following list.
      match /following/{followeeId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }

      // followers subcollection: any authenticated user may read;
      // the follower themselves creates/deletes their own entry via batch write.
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == followerId;
      }
    }

    // Posts collection
    // Users can read any post; can only write/update posts they authored.
    // authorUid matches the field defined in schema/firebase-schema.md.
    // Any authenticated user may increment/decrement likeCount only
    // (written atomically as part of a like/unlike batch write).
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == resource.data.authorUid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorUid;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']);

      // likes subcollection: any authenticated user may read (existence check);
      // the liker creates/deletes their own entry via batch write.
      match /likes/{userId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
