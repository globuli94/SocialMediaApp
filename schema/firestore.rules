rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    // Users can read any profile; can only write their own document.
    // followingCount and followerCount fields are updated in the same batch write
    // as the corresponding following/followers subcollection documents.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow any authenticated user to increment/decrement followerCount only
      // (written atomically as part of a follow/unfollow batch write).
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount']);

      // following subcollection: owner may create/delete their own following entries;
      // any authenticated user may read any user's following list.
      match /following/{followeeId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == userId;
      }

      // followers subcollection: any authenticated user may read;
      // the follower themselves creates/deletes their own entry via batch write.
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == followerId;
      }
    }

    // Posts collection
    // Users can read any post; can only write/update posts they authored.
    // authorUid matches the field defined in schema/firebase-schema.md.
    // likeCount is updated atomically as part of a like/unlike batch write by any
    // authenticated user — allowed via the targeted update rule below.
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == resource.data.authorUid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorUid;
      // Allow any authenticated user to increment/decrement likeCount only
      // (written atomically as part of a like/unlike batch write).
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']);

      // likes subcollection: any authenticated user may read;
      // a user may only create/delete their own like document (document ID == their UID).
      match /likes/{likerId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && request.auth.uid == likerId;
      }
    }

    // Notifications subcollection: users/{userId}/notifications
    // - Owner can list/read their own notifications.
    // - Any authenticated user can create a notification in any user's subcollection
    //   (required for like and follow events written by a third party).
    // - Owner can update only the `read` field on their own notification documents.
    // - No delete permitted.
    match /users/{userId}/notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // Conversations collection
    // Only participants (uids listed in participantUids) may read, create, or update
    // a conversation document. No other collection rules are affected.
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participantUids;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participantUids;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participantUids;

      // messages subcollection: participants may read and create messages.
      match /messages/{messageId} {
        allow read, create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantUids;
      }
    }
  }
}
